# Clay webhook for contact-list uploads (Intake & Triage)
# Either CLAY_CONTACT_WEBHOOK_URL or the legacy CLAY_WEBHOOK_URL works for contacts.
CLAY_CONTACT_WEBHOOK_URL=
CLAY_WEBHOOK_URL=

# Clay webhook for company-list uploads (Company Intake & Triage)
CLAY_COMPANY_WEBHOOK_URL=

# Optional: if you added auth on the Clay webhook source
CLAY_AUTH_TOKEN=

# Required for the admin section (clear submission history, approve large lists)
# Leave blank to hide the admin section entirely
ADMIN_PASSWORD=

# Supabase Postgres connection string for persistent storage
# Get this from Supabase -> Connect -> Direct (use Transaction Pooler URL on IPv4-only environments)
DATABASE_URL=
