# Paste your Clay webhook URL when ready (do not commit .env)
CLAY_WEBHOOK_URL=

# Optional: if you added auth on the Clay webhook source
CLAY_AUTH_TOKEN=

# Required for the admin section (clear submission history)
# Leave blank to hide the admin section entirely
ADMIN_PASSWORD=

# Supabase Postgres connection string for persistent storage
# Get this from Supabase -> Connect -> Direct
DATABASE_URL=
